# ──────────────────────────────────────────────
# NEURO CONTROL PLANE — PRODUCTION TEMPLATE
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

PORT=8787

# Admin dashboard access token (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
NEURO_ADMIN_TOKEN=

# Database (Railway Postgres or local)
DATABASE_URL=
DATABASE_SSL=require

# TON Blockchain
TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
NEURO_VAULT_ADDRESS=

# Signature verification: domains allowed to submit signed wallet actions
ALLOWED_SIGN_DOMAINS=neuroton-lime.vercel.app,localhost:5173

# Cron job secret (required — no default. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET=

# Frontend URLs
VITE_CONTROL_PLANE_URL=
VITE_APP_URL=https://neuroton-lime.vercel.app

# Telegram
VITE_TELEGRAM_BOT_USERNAME=NeuroTONbot

# TON APIs
VITE_TONSTAKERS_PARTNER_CODE=
VITE_TONAPI_KEY=

# Server-side API key (same value as VITE_TONAPI_KEY but for backend use)
TONAPI_KEY=

# ⚠️ NEVER commit mnemonics or private keys to this file
# Store wallet mnemonics ONLY in Railway/Render environment secrets
