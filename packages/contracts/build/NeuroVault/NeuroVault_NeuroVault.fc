    }
    
    ;; Receive ExecDelegate message
    if (op == 1258179490) {
        var $msg'target = in_msg~load_msg_addr();
        var $msg'amount = in_msg~load_varuint16();
        var $msg'mode = in_msg~load_uint(8);
        var $msg'payload = in_msg~load_maybe_ref();
        ($self'owner, $self'totalAssets, $self'totalShares, $self'sharesMap, $self'performanceFeePrecise)~$NeuroVault$_fun_requireOwner();
        $global_send($SendParameters$_constructor_to_value_mode_body($msg'target, $msg'amount, $msg'mode, $msg'payload));
        $NeuroVault$_contract_store(($self'owner, $self'totalAssets, $self'totalShares, $self'sharesMap, $self'performanceFeePrecise));
