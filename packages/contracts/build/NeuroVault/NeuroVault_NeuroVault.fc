;; Routing of a Contract NeuroVault
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'operator, $self'totalSupply, $self'totalAssets, $self'performanceFeePrecise, $self'minDepositAmount, $self'autoCompoundCap, $self'maxDelegatePercent, $self'depositFeePrecise, $self'paused, $self'whitelistCount, $self'whitelist1, $self'whitelist2, $self'whitelist3, $self'whitelist4, $self'whitelist5, $self'content, $self'mintable) = $NeuroVault$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
        ;; Receive Deposit message
        if (op == 2393262120) {
            var $msg'intent = in_msg~load_uint(8);
            ($self'owner, $self'operator, $self'totalSupply, $self'totalAssets, $self'performanceFeePrecise, $self'minDepositAmount, $self'autoCompoundCap, $self'maxDelegatePercent, $self'depositFeePrecise, $self'paused, $self'whitelistCount, $self'whitelist1, $self'whitelist2, $self'whitelist3, $self'whitelist4, $self'whitelist5, $self'content, $self'mintable)~$NeuroVault$_fun_requireNotPaused();
            var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
            int $depositVal = $ctx'value;
            throw_unless(4894, ($depositVal >= $self'minDepositAmount));
            throw_unless(21273, ($depositVal > ($self'owner, $self'operator, $self'totalSupply, $self'totalAssets, $self'performanceFeePrecise, $self'minDepositAmount, $self'autoCompoundCap, $self'maxDelegatePercent, $self'depositFeePrecise, $self'paused, $self'whitelistCount, $self'whitelist1, $self'whitelist2, $self'whitelist3, $self'whitelist4, $self'whitelist5, $self'content, $self'mintable)~$NeuroVault$_fun_reserveGas()));
            int $netDeposit = ($depositVal - ($self'owner, $self'operator, $self'totalSupply, $self'totalAssets, $self'performanceFeePrecise, $self'minDepositAmount, $self'autoCompoundCap, $self'maxDelegatePercent, $self'depositFeePrecise, $self'paused, $self'whitelistCount, $self'whitelist1, $self'whitelist2, $self'whitelist3, $self'whitelist4, $self'whitelist5, $self'content, $self'mintable)~$NeuroVault$_fun_reserveGas());
            int $entryFee = (($netDeposit * $self'depositFeePrecise) / 10000);
            int $depositAfterFee = ($netDeposit - $entryFee);
            int $effectiveSupply = ($self'totalSupply + 1000000);
            int $effectiveAssets = ($self'totalAssets + 1000000);
            int $sharesToMint = (($depositAfterFee * $effectiveSupply) / $effectiveAssets);
            throw_unless(3256, ($sharesToMint > 0));
            $self'totalAssets = ($self'totalAssets + $netDeposit);
            $self'totalSupply = ($self'totalSupply + $sharesToMint);
            ($self'owner, $self'operator, $self'totalSupply, $self'totalAssets, $self'performanceFeePrecise, $self'minDepositAmount, $self'autoCompoundCap, $self'maxDelegatePercent, $self'depositFeePrecise, $self'paused, $self'whitelistCount, $self'whitelist1, $self'whitelist2, $self'whitelist3, $self'whitelist4, $self'whitelist5, $self'content, $self'mintable)~$NeuroVault$_fun_mintTokens($ctx'sender, $sharesToMint, $ctx'sender);
            $NeuroVault$_contract_store(($self'owner, $self'operator, $self'totalSupply, $self'totalAssets, $self'performanceFeePrecise, $self'minDepositAmount, $self'autoCompoundCap, $self'maxDelegatePercent, $self'depositFeePrecise, $self'paused, $self'whitelistCount, $self'whitelist1, $self'whitelist2, $self'whitelist3, $self'whitelist4, $self'whitelist5, $self'content, $self'mintable));
            return ();
        }
        
        ;; Receive TokenBurnNotification message
        if (op == 0x7bdd97de) {
            var $msg'queryId = in_msg~load_uint(64);
            var $msg'amount = in_msg~load_varuint16();
            var $msg'sender = in_msg~load_msg_addr();
            var $msg'response_destination = in_msg~__tact_load_address_opt();
            var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
            slice $expectedWallet = $global_contractAddress($NeuroJettonWallet$_init_child($global_myAddress(), $msg'sender));
            throw_unless(2306, ( equal_slices_bits($ctx'sender, $expectedWallet) ));
            throw_unless(25223, ($msg'amount > 0));
            throw_unless(36625, ($self'totalSupply >= $msg'amount));
            int $effectiveSupply = ($self'totalSupply + 1000000);
            int $effectiveAssets = ($self'totalAssets + 1000000);
            int $tonToRelease = (($msg'amount * $effectiveAssets) / $effectiveSupply);
            throw_unless(61441, ($tonToRelease > 0));
            if (($tonToRelease > $self'totalAssets)) {
                $tonToRelease = $self'totalAssets;
            }
            throw_unless(4675, ($self'totalAssets >= $tonToRelease));
            $self'totalSupply = ($self'totalSupply - $msg'amount);
            $self'totalAssets = ($self'totalAssets - $tonToRelease);
            slice $dest = $msg'sender;
            if ((~ null?($msg'response_destination))) {
                $dest = __tact_not_null($msg'response_destination);
