        $self'totalShares = ($self'totalShares - $msg'shares);
        $self'totalAssets = ($self'totalAssets - $tonOut);
        $global_send($SendParameters$_constructor_to_value_mode_body($ctx'sender, $tonOut, 2, __gen_cell_cell_cd59fca2cdc29a9dbf46f2d496e4f92567460f0153a92a74b954cd50ef59cf39()));
        $NeuroVault$_contract_store(($self'owner, $self'totalAssets, $self'totalShares, $self'sharesMap, $self'performanceFeePrecise));
