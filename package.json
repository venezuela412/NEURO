{
  "name": "neuro",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @neuro/miniapp dev",
    "dev:miniapp": "pnpm --filter @neuro/miniapp dev",
    "dev:control-plane": "pnpm --filter @neuro/control-plane dev",
    "build": "pnpm --filter @neuro/miniapp build",
    "build:control-plane": "pnpm --filter @neuro/control-plane build",
    "lint": "pnpm --filter @neuro/miniapp lint",
    "check": "pnpm build && pnpm build:control-plane && pnpm lint",
    "start:control-plane": "pnpm --filter @neuro/control-plane start",
    "preview:miniapp": "pnpm --filter @neuro/miniapp preview",
    "deploy:test": "docker compose up --build"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
