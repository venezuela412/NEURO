{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@neuro/shared": ["packages/shared/src/index.ts"],
      "@neuro/domain": ["packages/domain/src/index.ts"],
      "@neuro/adapters": ["packages/adapters/src/index.ts"]
    }
  }
}
